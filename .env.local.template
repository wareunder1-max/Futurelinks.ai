# AI FutureLinks Platform - Local Environment Configuration Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control!

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Vercel Postgres connection strings
# For local development: Use a local Postgres instance or Vercel Postgres dev database
# For production: These will be automatically populated by Vercel

# Connection pooling URL (used by Prisma Client in serverless environments)
DATABASE_URL="postgres://default:password@localhost:5432/ai_futurelinks?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection URL (used for migrations)
DIRECT_URL="postgres://default:password@localhost:5432/ai_futurelinks?sslmode=require"

# =============================================================================
# SECURITY & ENCRYPTION
# =============================================================================
# ENCRYPTION_KEY: 32-byte hex string for AES-256-GCM encryption of API keys
# Generate a new key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Keep this secret and never share it!
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# =============================================================================
# NEXTAUTH CONFIGURATION
# =============================================================================
# NEXTAUTH_URL: The canonical URL of your site
# For local development: http://localhost:3000
# For production: https://ai.futurelinks.art
NEXTAUTH_URL="http://localhost:3000"

# NEXTAUTH_SECRET: Secret key for signing and encrypting tokens
# Generate with: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# =============================================================================
# GOOGLE OAUTH CREDENTIALS
# =============================================================================
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID
# 2. Set authorized redirect URIs to: http://localhost:3000/api/auth/callback/google
# 3. For production, add: https://ai.futurelinks.art/api/auth/callback/google

GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =============================================================================
# EMAIL PROVIDER (OPTIONAL)
# =============================================================================
# For magic link authentication via email
# Configure your SMTP server details here
# Format: smtp://username:password@smtp.example.com:587
# Or use a service like SendGrid, Mailgun, etc.

EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
EMAIL_FROM="noreply@futurelinks.art"

# =============================================================================
# INITIAL ADMIN CREDENTIALS
# =============================================================================
# These credentials are used to create the first admin account
# Change these immediately after first login!
# Password must be at least 8 characters

INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="change-this-password-immediately"

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env.local
# 2. Generate ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Generate NEXTAUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 4. Set up Google OAuth credentials at https://console.cloud.google.com/
# 5. Update DATABASE_URL with your actual database connection string
# 6. Change INITIAL_ADMIN_PASSWORD to a strong password
# 7. Run: npm run db:migrate to set up the database
# 8. Run: npm run db:seed to create the initial admin account
