# AI FutureLinks Platform - Environment Variables Example
# This file shows the structure of required environment variables
# Copy to .env.local and fill in actual values
# See docs/ENVIRONMENT_SETUP.md for detailed setup instructions

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Vercel Postgres connection strings
# For local development: Use a local Postgres instance or Vercel Postgres dev database
# For production: These will be automatically populated by Vercel

# Connection pooling URL (used by Prisma Client in serverless environments)
DATABASE_URL="postgres://default:password@localhost:5432/ai_futurelinks?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection URL (used for migrations)
DIRECT_URL="postgres://default:password@localhost:5432/ai_futurelinks?sslmode=require"

# =============================================================================
# SECURITY & ENCRYPTION
# =============================================================================
# ENCRYPTION_KEY: 32-byte hex string for AES-256-GCM encryption of API keys
# Generate with: node scripts/generate-keys.js
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# =============================================================================
# NEXTAUTH CONFIGURATION
# =============================================================================
# NEXTAUTH_URL: The canonical URL of your site
# Local: http://localhost:3000
# Production: https://ai.futurelinks.art
NEXTAUTH_URL="http://localhost:3000"

# NEXTAUTH_SECRET: Secret key for signing and encrypting tokens
# Generate with: node scripts/generate-keys.js
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# =============================================================================
# GOOGLE OAUTH CREDENTIALS
# =============================================================================
# Get these from: https://console.cloud.google.com/apis/credentials
# See docs/ENVIRONMENT_SETUP.md for detailed setup instructions
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =============================================================================
# EMAIL PROVIDER (OPTIONAL)
# =============================================================================
# For magic link authentication via email
EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
EMAIL_FROM="noreply@futurelinks.art"

# =============================================================================
# INITIAL ADMIN CREDENTIALS
# =============================================================================
# Used to create the first admin account (change after first login!)
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="change-this-password-immediately"

# =============================================================================
# MONITORING & ERROR TRACKING
# =============================================================================
# Sentry DSN for error tracking and performance monitoring
# Get from: https://sentry.io/settings/projects/
# Leave empty to disable Sentry in development
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Sentry organization and project (for source maps upload)
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"

# Sentry auth token (for uploading source maps during build)
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# Stored in .env.sentry-build-plugin (auto-generated by Sentry wizard)
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Enable/disable Sentry in different environments
NEXT_PUBLIC_SENTRY_ENABLED="true"
